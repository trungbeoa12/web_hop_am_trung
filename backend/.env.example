# Sao chép file này thành .env và điền giá trị thực

# Bắt buộc. Dùng connection string PostgreSQL từ Supabase hoặc Render.
# Ví dụ:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
DATABASE_URL=

# Mật khẩu admin để đăng nhập và ghi dữ liệu.
# Nếu không set, backend sẽ tạm dùng SECRET_KEY cũ làm mật khẩu tương thích ngược.
ADMIN_PASSWORD=

# Secret để ký token admin. Nếu không set, backend sẽ tạm dùng SECRET_KEY cũ.
ADMIN_TOKEN_SECRET=

# Danh sách origin được phép gọi API, ngăn cách bởi dấu phẩy
# Thay bằng domain Vercel thực của bạn, ví dụ:
# ALLOWED_ORIGINS=https://trung-beo-chords.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5500

# Legacy fallback. Có thể để trống nếu đã set ADMIN_PASSWORD và ADMIN_TOKEN_SECRET.
SECRET_KEY=
