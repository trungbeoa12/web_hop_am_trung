# Sao chép file này thành .env và điền giá trị thực

# Đường dẫn đến file DB (Railway Volume phải mount tại /data)
DB_PATH=/data/songs.db

# Danh sách origin được phép gọi API, ngăn cách bởi dấu phẩy
# Thay bằng domain Vercel thực của bạn, ví dụ:
# ALLOWED_ORIGINS=https://trung-beo-chords.vercel.app
ALLOWED_ORIGINS=*

# Secret key để bảo vệ API Thêm/Xóa bài hát
# Tạo key mạnh bằng: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=thay-bang-mot-chuoi-bi-mat-manh
